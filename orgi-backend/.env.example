# ORGI - Backend Configuration
# Copiar a .env y ajustar según entorno

# Base de Datos
DATABASE_URL=sqlite:///./data/orgi_dev.db
# Para producción con PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/orgi_db

# Seguridad JWT
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# Entorno
ENVIRONMENT=development

# PDF Processing
MAX_PDF_SIZE_MB=10

# Ruta a la base de datos existente (para migración de datos)
EXISTING_DB_PATH=../Database app/MyFinance.db
